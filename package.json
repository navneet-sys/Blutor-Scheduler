{
  "name": "blutor-scheduler",
  "version": "1.0.0",
  "description": "Standalone scheduler service for Blutor creator data refresh",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run build && cross-env NODE_ENV=development node dist/index.js",
    "build": "swc src -d dist --source-maps --copy-files",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "deploy:prod": "npm run build && pm2 start ecosystem.config.js --only blutor-scheduler"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.231.0",
    "@aws-sdk/client-sqs": "^3.231.0",
    "@aws-sdk/s3-request-presigner": "^3.231.0",
    "axios": "^1.2.0",
    "country-list": "^2.3.0",
    "dotenv": "^16.0.1",
    "googleapis": "^142.0.0",
    "moment-timezone": "^0.5.45",
    "mongoose": "^6.5.0",
    "node-cron": "^3.0.3",
    "reflect-metadata": "^0.1.13",
    "twitter-api-v2": "^1.17.0",
    "winston": "^3.8.1",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@swc/cli": "^0.1.57",
    "@swc/core": "^1.2.220",
    "@types/express": "^5.0.6",
    "@types/node": "^17.0.45",
    "@types/node-cron": "^3.0.7",
    "cross-env": "^7.0.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^4.7.4"
  }
}
